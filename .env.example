# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Supabase — https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Models (defaults used if empty)
CHAT_MODEL=google/gemini-2.0-flash-001
ANALYSIS_MODEL=meta-llama/llama-3.1-8b-instruct

# Telegram Bot — @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Mistral — for Voxtral TTS (https://console.mistral.ai/api-keys)
MISTRAL_API_KEY=

# Cron secret — any random string
CRON_SECRET=tr_ar_cron_2024

# Your VPS domain or IP (no trailing slash) — used in Telegram links
NEXT_PUBLIC_APP_URL=https://your-domain.com
