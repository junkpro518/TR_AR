# ═══════════════════════════════════════════════════
#  TR-AR — متغيرات البيئة
#  انسخ هذا الملف إلى .env وأضف قيمك الفعلية
#  cp .env.example .env
# ═══════════════════════════════════════════════════

# ── Supabase (مطلوب) ─────────────────────────────────
# Project URL: Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon (public) key: Dashboard → Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (سري — لا تشاركه أبداً): Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenRouter (مطلوب) ───────────────────────────────
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── النماذج (اختياري — القيم الافتراضية مدرجة) ──────
CHAT_MODEL=google/gemini-2.0-flash-001
ANALYSIS_MODEL=meta-llama/llama-3.1-8b-instruct

# ── Telegram Bot (اختياري — للإشعارات والموافقات) ────
# 1. أنشئ بوت عبر @BotFather واحصل على التوكن
# 2. ابدأ محادثة مع البوت ثم افتح:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    وانسخ "from.id" من الاستجابة
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Mistral TTS (اختياري — للصوت التركي) ─────────────
# https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# ── Serper (اختياري — للبحث في الإنترنت) ─────────────
# https://serper.dev — مجاني 2500 بحث/شهر
SERPER_API_KEY=

# ── الإعدادات العامة ──────────────────────────────────
# رابط التطبيق (بدون trailing slash) — يُستخدم في روابط التيليجرام
NEXT_PUBLIC_APP_URL=https://tr-ar.junkpro.duckdns.org

# Cron secret — أي نص عشوائي لحماية endpoint التذكير اليومي
CRON_SECRET=change_this_to_a_random_secret
